{
    "name": "@digia/moengage-react-native",
    "version": "0.1.0",
    "description": "Pure TypeScript Digia CEP plugin for MoEngage – works on both Android and iOS",
    "main": "lib/commonjs/index",
    "module": "lib/module/index",
    "types": "lib/typescript/src/index.d.ts",
    "react-native": "src/index",
    "source": "src/index",
    "exports": {
        ".": {
            "import": "./lib/module/index.js",
            "require": "./lib/commonjs/index.js",
            "types": "./lib/typescript/src/index.d.ts"
        }
    },
    "files": [
        "src",
        "lib",
        "!lib/typescript/example"
    ],
    "scripts": {
        "typecheck": "tsc --noEmit",
        "build": "bob build",
        "prepare": "bob build"
    },
    "keywords": [
        "react-native",
        "digia",
        "moengage",
        "cep",
        "in-app"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/Digia-Technology-Private-Limited/digia_moengage.git",
        "directory": "react-native"
    },
    "author": "Digia Technology Private Limited",
    "license": "MIT",
    "peerDependencies": {
        "react": "*",
        "react-native": "*",
        "@digia/engage-react-native": "*",
        "react-native-moengage": "*"
    },
    "devDependencies": {
        "@types/react": "^18.2.0",
        "@types/react-native": "^0.73.0",
        "react": "18.2.0",
        "react-native": "0.73.0",
        "react-native-builder-bob": "^0.23.0",
        "typescript": "^5.2.0"
    },
    "react-native-builder-bob": {
        "source": "src",
        "output": "lib",
        "targets": [
            "commonjs",
            "module",
            [
                "typescript",
                {
                    "project": "tsconfig.build.json"
                }
            ]
        ]
    }
}